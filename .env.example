# AI 内容运营 Agent
# 环境变量模板 — 复制为 .env 并填入真实值

# ── 模型 API ──
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

DASHSCOPE_API_KEY=sk-xxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Claude Code / Anthropic（可选，后期版本三启用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── 微信通知（Hermes 集成） ──
# 如果你通过 Hermes 连接了微信，这里不需要额外配置
# 如果独立使用企业微信机器人：
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# ── 抖音创作者平台 ──
DOUYIN_OPEN_ID=xxxxxxxx
DOUYIN_ACCESS_TOKEN=xxxxxxxx

# ── 数据存储 ──
DATABASE_URL=sqlite:///data/operator.db

# ── 投流（巨量引擎，后期启用）──
OCEAN_ENGINE_ADVERTISER_ID=xxxxxxxx
OCEAN_ENGINE_API_KEY=xxxxxxxx
